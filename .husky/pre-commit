echo "🔍 Checking TypeScript errors..."

# Check client
echo "📱 Checking client..."
cd client && npm run type-check
if [ $? -ne 0 ]; then
  echo "❌ Client TypeScript errors found!"
  exit 1
fi

echo "🔍 Checking ESLint..."
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ Client ESLint errors found!"
  exit 1
fi

# Check server
echo "🖥️  Checking server..."
cd ../server && npm run build
if [ $? -ne 0 ]; then
  echo "❌ Server TypeScript errors found!"
  exit 1
fi

echo "✅ All checks passed!"
